# Resend email API — required for email sending feature
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# From address shown to recipients (must be a verified domain in Resend)
EMAIL_FROM="Yorgos AI <offers@example.com>"

# Optional reply-to address
EMAIL_REPLY_TO=

# AI review proxy — required for AI dictation review feature
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
